{
  // ─────────────────────────────────────────────
  //  FILES
  // ─────────────────────────────────────────────
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ─────────────────────────────────────────────
  //  EDITOR — APARÊNCIA
  // ─────────────────────────────────────────────
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.4,
  "editor.fontLigatures": true,
  "editor.rulers": [120, 200],
  "editor.wordWrap": "on",
  "editor.renderLineHighlight": "gutter",
  "editor.renderWhitespace": "boundary",
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "auto",
  "editor.scrollbar.horizontal": "visible",
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.smoothScrolling": true,
  "editor.letterSpacing": 0.3,

  // ─────────────────────────────────────────────
  //  EDITOR — EXPERIÊNCIA DE EDIÇÃO
  // ─────────────────────────────────────────────
  "editor.semanticHighlighting.enabled": true,
  "editor.parameterHints.enabled": false,
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.tabSize": 4,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.linkedEditing": true,
  "editor.largeFileOptimizations": true,

  // Bracket pairs (você não tinha isso — muito útil!)
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,

  // Sticky scroll — mantém contexto da função visível ao scrollar
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,

  // Inlay hints — tipos inline (muito útil em TS e Python)
  "editor.inlayHints.enabled": "offUnlessPressed",

  // ─────────────────────────────────────────────
  //  WORKBENCH
  // ─────────────────────────────────────────────
  "workbench.startupEditor": "none",
  "workbench.iconTheme": "symbols",
  "workbench.editor.labelFormat": "short",
  "workbench.layoutControl.enabled": true,
  "workbench.preferredDarkColorTheme": "GitHub Dark",
  "workbench.preferredLightColorTheme": "Min Dark",
  "workbench.activityBar.location": "hidden",
  "workbench.tree.indent": 14,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.colorTheme": "Kolada",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.settings.applyToAllProfiles": ["workbench.colorCustomizations"],

  // ─────────────────────────────────────────────
  //  WINDOW
  // ─────────────────────────────────────────────
  "window.autoDetectHighContrast": true,
  "window.autoDetectColorScheme": false,
  "window.titleBarStyle": "custom",
  "window.commandCenter": false,

  // ─────────────────────────────────────────────
  //  EXPLORER
  // ─────────────────────────────────────────────
  "explorer.compactFolders": false,
  "explorer.sortOrder": "foldersNestsFiles",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    // TypeScript / JavaScript
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "*.css": "${capture}.module.css, ${capture}.module.scss",

    // Config files
    "tsconfig.json": "tsconfig.*.json",
    "package.json": ".eslint*, prettier*, tsconfig*, vite*, pnpm-*, bun.lockb, nest*, package-lock*, yarn.lock",
    "tailwind.config.*": "tailwind.config*, postcss.config*",
    ".env.local": ".env*",
    ".env": ".env*",

    // Docker
    "Dockerfile": "docker-compose*, .dockerignore",

    // Docs
    "README.md": "*.md, LICENSE*, CHANGELOG*",

    // Databases
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*",

    // Python
    "pyproject.toml": "poetry.lock, requirements*.txt, setup.py, setup.cfg, .python-version",
    "*.py": "${capture}.pyi"
  },

  // ─────────────────────────────────────────────
  //  BREADCRUMBS & OUTLINE
  // ─────────────────────────────────────────────
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "outline.showVariables": true,
  "outline.showFunctions": true,

  // ─────────────────────────────────────────────
  //  TERMINAL
  // ─────────────────────────────────────────────
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.showExitAlert": false,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.persistentSessionReviveProcess": "never",

  // ─────────────────────────────────────────────
  //  SEARCH
  // ─────────────────────────────────────────────
  "search.followSymlinks": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/build": true,
    "**/.venv": true
  },

  // ─────────────────────────────────────────────
  //  GIT
  // ─────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "diffEditor.ignoreTrimWhitespace": true,

  // ─────────────────────────────────────────────
  //  TYPESCRIPT / JAVASCRIPT
  // ─────────────────────────────────────────────
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.autoImports": true,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.variableTypes.enabled": false,
  "typescript.inlayHints.returnTypes.enabled": true,

  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.autoImports": true,

  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },

  // ─────────────────────────────────────────────
  //  PYTHON
  // ─────────────────────────────────────────────
  "python.createEnvironment.trigger": "off",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.inlayHints.functionReturnTypes": true,

  "[python]": {
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.formatOnType": false,
    "editor.defaultFormatter": "eeyore.yapf",
    "editor.tabSize": 4
  },

  // ─────────────────────────────────────────────
  //  C++
  // ─────────────────────────────────────────────
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: Google, IndentWidth: 4, ColumnLimit: 120 }",
  "C_Cpp.inlayHints.parameterNames.enabled": true,
  "C_Cpp.inlayHints.autoDeclarationTypes.enabled": false,

  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 4
  },

  // ─────────────────────────────────────────────
  //  HTML / CSS
  // ─────────────────────────────────────────────
  "emmet.formatExpansion": true,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },

  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "[scss]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },

  // ─────────────────────────────────────────────
  //  JSON
  // ─────────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  // ─────────────────────────────────────────────
  //  PRETTIER
  // ─────────────────────────────────────────────
  "prettier.printWidth": 80,
  "prettier.jsxSingleQuote": true,
  "prettier.bracketSameLine": false,

  // ─────────────────────────────────────────────
  //  ESLINT
  // ─────────────────────────────────────────────
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "graphql"
  ],

  // ─────────────────────────────────────────────
  //  SPELL CHECK
  // ─────────────────────────────────────────────
  "cSpell.language": "en,pt",
  "cSpell.userWords": [
    "automations",
    "bootcamp",
    "chakra",
    "datadog",
    "esbuild",
    "fastify",
    "nestjs",
    "postgresql",
    "tailwindcss",
    "unform"
  ],

  // ─────────────────────────────────────────────
  //  LIVE SERVER
  // ─────────────────────────────────────────────
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.AdvanceCustomBrowserCmdLine": "",

  // ─────────────────────────────────────────────
  //  GITHUB COPILOT (desativado)
  // ─────────────────────────────────────────────
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "cpp": false
  },

  // ─────────────────────────────────────────────
  //  APC CUSTOMIZE UI
  // ─────────────────────────────────────────────
  "apc.electron": {
    "titleBarStyle": "hidden",
    "trafficLightPosition": { "x": 11, "y": 10 },
    "opacity": 0.3,
    "frame": false
  },
  "apc.header": { "height": 36 },
  "apc.listRow": { "height": 24 },
  "apc.stylesheet": {
    ".title-label > h2": "display: none",
    ".editor-actions": "display: flex",
    ".nosidebar .inline-tabs-placeholder": "width: 75px",
    ".pane-header": "padding: 0 8px",
    ".pane-body": "padding: 8px",
    ".split-view-view:first-child .pane-header": "display: none !important;",
    ".monaco-list-row": "border-radius: 4px;",
    ".monaco-workbench .monaco-list:not(.element-focused):focus:before": "display: none;"
  },

  // ─────────────────────────────────────────────
  //  OUTROS
  // ─────────────────────────────────────────────
  "glassit.alpha": 180,
  "console-ninja.featureSet": "Community",

  // ─────────────────────────────────────────────
  //  TOKEN COLOR CUSTOMIZATIONS (Tema Kolada)
  // ─────────────────────────────────────────────
  "editor.tokenColorCustomizations": {
    "[Kolada]": {
      "textMateRules": [
        {
          "scope": "keyword",
          "settings": { "foreground": "#000000" }
        },
        {
          "scope": ["entity.name.function", "support.function"],
          "settings": { "foreground": "#f200ff" }
        },
        {
          "scope": ["variable", "entity.name"],
          "settings": { "foreground": "#00FFFF" }
        },
        {
          "scope": "variable.parameter",
          "settings": { "foreground": "#77ecf0" }
        },
        {
          "scope": [
            "punctuation.definition.list.begin",
            "punctuation.definition.list.end",
            "punctuation.definition.dict.begin",
            "punctuation.definition.dict.end",
            "punctuation.section"
          ],
          "settings": { "foreground": "#FF69B4" }
        },
        {
          "scope": "keyword.operator",
          "settings": { "foreground": "#00B7EB" }
        },
        {
          "scope": ["variable.other.constant"],
          "settings": { "foreground": "#71ffbd", "fontStyle": "bold" }
        },
        {
          "scope": [
            "variable.other.readwrite",
            "constant.numeric",
            "constant.language"
          ],
          "settings": { "foreground": "#ff0c9e" }
        },
        {
          "scope": ["keyword.other.important", "keyword.other.important.css"],
          "settings": { "foreground": "#3fafd1", "fontStyle": "bold" }
        },
        {
          "scope": "keyword.other.definition.ini",
          "settings": { "foreground": "#33ff00" }
        },
        {
          "scope": "keyword.other.using.directive.cpp",
          "settings": { "foreground": "#11c7f5" }
        },
        {
          "scope": ["entity.name.tag.html", "entity.name.tag"],
          "settings": { "foreground": "#F04F6A", "fontStyle": "bold" }
        },
        {
          "scope": ["entity.name.tag.js.jsx"],
          "settings": { "foreground": "#F04F6A", "fontStyle": "bold" }
        },
        {
          "scope": ["punctuation.definition.tag"],
          "settings": { "foreground": "#ffffff", "fontStyle": "bold" }
        },
        {
          "scope": ["entity.other.attribute-name.html"],
          "settings": { "foreground": "#ffffff" }
        },
        {
          "scope": ["entity.other.attribute-name.js"],
          "settings": { "foreground": "#e4b841" }
        }
      ]
    }
  }
}
